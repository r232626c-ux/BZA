{
  "name": "bza",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "pg": "^8.17.2",
    "pg-promise": "^12.3.0"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.biozone.app",
    "files": [
      "../frontend/dist/**",
      "../backend/**",
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../backend/run_app.exe",
        "to": "backend/run_app.exe",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "artifactName": "BZA-${version}.${ext}"
    }
  }
}
